---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';

import { siteConfig } from '@/app/config/site';
import BaseLayout from '@/app/layouts/base-layout.astro';
import FeaturedPosts from '@/entities/post/featured-posts.astro';
import Posts from '@/entities/post/posts.astro';
import Button from '@/shared/ui/base/button.astro';
import HeadingBlock from '@/shared/ui/layout/heading-block.astro';
import Pagination from '@/shared/ui/layout/pagination.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.isDraft);
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
const numberOfPages = Math.ceil(sortedPosts.length / siteConfig.postsPerPage);
export const getStaticPaths = (async ({ paginate }) => {
  // data
  const allPosts = await getCollection('posts', ({ data }) => !data.isDraft);
  return paginate(
    allPosts.sort((a, b) => {
      return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
    }),
    {
      pageSize: siteConfig.postsPerPage,
    }
  );
}) satisfies GetStaticPaths;

const { page } = Astro.props;

// Use last 3 posts as featured
const featuredPosts = page.data.slice(0, 3);
const recentPosts = page.data.slice(3, page.data.length);

const title =
  page.currentPage === 1 ? siteConfig.title : siteConfig.title + ' ' + 'Page ' + page.currentPage;
const description =
  page.currentPage === 1 ?
    siteConfig.description
  : siteConfig.description + ' - Page ' + page.currentPage;
---

<BaseLayout
  title={title}
  description={description}>
  <section class='main'>
    {
      page.currentPage === 1 ?
        <HeadingBlock
          title={siteConfig.mainHeadTitle}
          description={
            'JSDev.Space publishes practical JavaScript and TypeScript tutorials focused on real implementation details, not theory-only overviews. Most articles include working code, architecture notes, and trade-offs you can apply in production.'
          }
          headingTwo={
            'Use categories and tags to filter by stack (React, Node.js, TypeScript, Web APIs), or open the latest posts below and follow the pagination for the full archive.'
          }
        />
      : <HeadingBlock
          title={siteConfig.shortTitle + ' - Page ' + page.currentPage}
          description={`Archive page ${page.currentPage} collects older JavaScript and TypeScript posts that are
            still relevant for day-to-day development.`}
          headingTwo={
            'Continue browsing to find implementation patterns, debugging guides, and framework-specific tutorials from previous releases.'
          }
        />
    }
    {page.currentPage === 1 && <FeaturedPosts posts={featuredPosts} />}
    {recentPosts && <Posts posts={page.currentPage === 1 ? recentPosts : page.data} />}
    {
      numberOfPages > 1 && (
        <Pagination
          currentPage={page.currentPage}
          numPages={numberOfPages}
          slug='/'
        />
      )
    }
  </section>

  <style>
    .archive-intro {
      margin: 0.75rem 0 1.5rem;
      color: hsl(var(--muted-foreground));
      line-height: 1.75;
    }

    .archive-intro p {
      margin: 0.5rem 0;
    }
  </style>
</BaseLayout>
