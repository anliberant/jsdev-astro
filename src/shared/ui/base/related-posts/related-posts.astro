---
import { getCollection } from 'astro:content';

import RelatedCard from './related-card.astro';

export interface Props {
  slug: string;
  collection: 'posts' | 'howtos' | 'fridays' | 'snippets';
}

const MAX_RELATED = 6;
const { slug, collection } = Astro.props;

const collectionsToSearch = ['posts', 'howtos', 'snippets'] as const;

const allItems = (
  await Promise.all(
    collectionsToSearch.map(async name => {
      const items = await getCollection(name, ({ data }) => !data.isDraft);
      return items.map(item => ({ ...item, _collection: name }));
    })
  )
).flat();

const currentPost = allItems.find(
  p => p.data.slug === slug && p._collection === collection
);

if (!currentPost) {
  throw new Error(`Current post not found for slug: ${slug}`);
}

const currentTags: string[] = ('tags' in currentPost.data ? currentPost.data.tags : []) ?? [];
const currentCategory: string = ('category' in currentPost.data ? currentPost.data.category : '') ?? '';
const manualSlugs: string[] = ('relatedSlugs' in currentPost.data ? currentPost.data.relatedSlugs : []) ?? [];

const manualPosts = manualSlugs
  .map(s => allItems.find(p => p.data.slug === s))
  .filter(Boolean);

const manualSlugSet = new Set(manualSlugs);

function getRelevance(post: (typeof allItems)[number]): number {
  const postTags: string[] = ('tags' in post.data ? post.data.tags : []) ?? [];
  const postCategory: string = ('category' in post.data ? post.data.category : '') ?? '';

  let score = 0;
  if (postCategory && postCategory === currentCategory) score += 2;

  const tagSet = new Set(postTags.map(t => t.toLowerCase()));
  for (const tag of currentTags) {
    if (tagSet.has(tag.toLowerCase())) score += 1;
  }

  return score;
}

const remaining = MAX_RELATED - manualPosts.length;

const autoRelated = remaining > 0
  ? allItems
      .filter(p => p.data.slug !== slug && !manualSlugSet.has(p.data.slug))
      .map(p => ({ post: p, score: getRelevance(p) }))
      .filter(({ score }) => score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, remaining)
      .map(({ post }) => post)
  : [];

const related = [...manualPosts, ...autoRelated];
---

{
  related.length > 0 && (
    <div class='related-wrapper'>
      <h3 class='related-heading'>Related articles</h3>
      <section class='related-list'>
        {related.map(post => (
          <RelatedCard post={post} />
        ))}
      </section>
    </div>
  )
}

<style>
  .related-wrapper {
    margin-top: 2rem;
  }

  .related-heading {
    margin-bottom: 1rem;
    font-size: 1.25rem;
    font-weight: 600;
  }

  .related-list {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
  }
</style>
