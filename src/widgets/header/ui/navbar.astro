---
import { Rss } from '@lucide/astro';

import SearchWithData from '@/features/search/ui/search-with-data.astro';
import Logo from '@/shared/ui/base/logo.astro';

import Navigation from './navigation.astro';
import ThemeSwitcher from './theme-switcher.astro';

const githubIcon =
  '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>';
---

<>
  <a href='/' aria-label='Home' class='logo'>
    <Logo />
  </a>
  <Navigation />
  <div class='header-panel'>
    <!-- <Search /> -->
    <SearchWithData placeholder='Search posts, tutorials, and more...' />
    <div class='header-icons'>
      <ThemeSwitcher />
      <a
        href='https://jsdev.space/rss.xml'
        aria-label='RSS'
        class='group cursor-pointer'
      >
        <Rss
          size={20}
          stroke-width={1}
          class='transition-all duration-300 hover:scale-125 hover:fill-blueLight hover:stroke-blueLight'
        />
      </a>
      <a
        href='https://github.com/anliberant/jsdev-astro'
        aria-label='View source on GitHub'
        class='group cursor-pointer'
      >
        <span
          class='transition-all duration-300 hover:scale-125 hover:fill-blueLight hover:stroke-blueLight'
          set:html={githubIcon}
        />
      </a>
    </div>
  </div>
</>
<style>
  .logo {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 1.125rem;
    line-height: 1.75rem;
    font-weight: 600;
  }
  .header-panel {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    justify-content: flex-end;
    width: 7rem;
    min-width: 7rem;
    min-height: 4rem;
    flex-shrink: 0;
    margin-left: auto;
  }
  @media (min-width: 768px) {
    .header-panel {
      width: 16rem;
      min-width: 16rem;
      gap: 0.5rem;
    }
  }
  @media (min-width: 1024px) {
    .header-panel {
      width: 18rem;
      min-width: 18rem;
      gap: 1rem;
    }
    .logo {
      margin-right: 1rem;
    }
  }
  @media (min-width: 1280px) {
    .header-panel {
      width: 280px;
      min-width: 280px;
      gap: 2.5rem;
    }
    .logo {
      margin-right: 1.5rem;
    }
  }
  .header-icons {
    display: flex !important;
    gap: 0.75rem;
    align-items: center;
    min-width: 68px;
    padding-right: 1rem;
  }
</style>
