{
  "name": "jsdev",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "generate:og": "tsx generate-og-images.ts",
    "dev": "astro dev",
    "dev-dev": "npx astro dev --host 127.0.0.1 --port 3000",
    "start": "astro dev",
    "build": "npm run generate:og && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "clean": "rimraf node_modules/.vite dist .astro",
    "dev:clean": "npm run clean && npm install && npm run dev",
    "lint": "eslint . --ext .js,.ts,.astro",
    "lint:fix": "eslint . --ext .js,.ts,.astro --fix",
    "prettier": "prettier --write \"src/**/*.{js,ts,astro,json,md}\"",
    "prettier:check": "prettier --check .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/netlify": "^7.0.2",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@lucide/astro": "^0.577.0",
    "@netlify/blobs": "^10.7.2",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.0.4",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.13.0",
    "reading-time": "^1.5.0",
    "sanitize-html": "^2.17.1",
    "satori": "^0.25.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "ajv": "^8.18.0",
    "astro-eslint-parser": "^1.3.0",
    "eslint": "^10.0.3",
    "eslint-plugin-astro": "^1.6.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
