{
  "name": "jsdev",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "generate:og": "tsx generate-og-images.ts",
    "dev": "astro dev",
    "dev-dev": "npx astro dev --host 127.0.0.1 --port 3000",
    "start": "astro dev",
    "build": "npm run generate:og && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "clean": "rimraf node_modules/.vite dist .astro",
    "dev:clean": "npm run clean && npm install && npm run dev",
    "lint": "eslint . --ext .js,.ts,.astro",
    "lint:fix": "eslint . --ext .js,.ts,.astro --fix",
    "prettier": "prettier --write \"src/**/*.{js,ts,astro,json,md}\"",
    "prettier:check": "prettier --check .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/netlify": "^8.1.2",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@lucide/astro": "^1.24.0",
    "@netlify/blobs": "^10.7.9",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^7.0.9",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.3.0",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.16.0",
    "reading-time": "^1.5.0",
    "sanitize-html": "^2.17.6",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "ajv": "^8.20.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
